MONGO_URI=mongodb://127.0.0.1:27017/webtech_auth
JWT_SECRET=replace_this_with_a_secure_secret
PORT=5000
AUTO_START_MONGO=true
MONGO_DB_PATH=C:\data\db
# Optional: set this if mongod.exe is not already on PATH
# MONGOD_PATH=C:\Program Files\MongoDB\Server\8.3\bin\mongod.exe

# ===== EMAIL NOTIFICATION SYSTEM =====
# Email Service Provider: 'gmail' or 'smtp'
EMAIL_SERVICE=gmail

# For Gmail Service (recommended)
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the App Password below (not your regular password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# For SMTP Service (alternative - uncomment to use)
# EMAIL_SERVICE=smtp
# SMTP_HOST=smtp.yourmailserver.com
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_USER=your-email@domain.com
# EMAIL_PASSWORD=your-smtp-password
